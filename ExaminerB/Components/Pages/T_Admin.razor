    private async Task BtnDeleteTeacher (User teacher)
        {
        if ((teacher.UserTags & 1) == 1)
            {
            teacher.UserTags &= ~1;
            }
        else
            {
            teacher.UserTags |= 1;
            }
        teacher.UserRole = "teacher";
        bool result = await feService.Update_User(teacher);
        if (result)
            {
            lstTeachers = await feService.Read_Teachers(DepartmentId);
            Snackbar.Add($"teacher {strTeacherUsername} account updated", Severity.Success, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
            _cmd = "listteachers";
            StateHasChanged();
            }
        else
            {
            Snackbar.Add($"failed to update {strTeacherUsername}", Severity.Error, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
            }
        }
