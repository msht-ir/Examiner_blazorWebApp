    private async Task BtnCreateNewTeacher ()
        {
        if ((strTeacherUsername.Trim() == "") || (strTeacherPassword.Trim() == "") || (strTeacherNickname.Trim() == "") || (strTeacherEmail.Trim() == ""))
            {
            Snackbar.Add($"fill in blanks", Severity.Warning, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
            return;
            }
        else
            {
            int _departmentId = DepartmentId;
            User teacher = new User()
                {
                DepartmentId = _departmentId,
                UserName = strTeacherUsername,
                UserPass = strTeacherPassword,
                UserNickname = strTeacherNickname,
                UserEmail = strTeacherEmail,
                UserTags = 1,
                UserRole = "teacher"
                };
            bool result = await feService.Create_Teacher(teacher);
            if (result)
                {
                lstTeachers = await feService.Read_Teachers(DepartmentId);
                Snackbar.Add($"teacher {strTeacherUsername} - {strTeacherNickname} created", Severity.Success, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
                _cmd = "";
                StateHasChanged();
                }
            else
                {
                Snackbar.Add($"failed to create {strTeacherUsername}", Severity.Error, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
                }
            }
        }
