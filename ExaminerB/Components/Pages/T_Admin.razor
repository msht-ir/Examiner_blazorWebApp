        {
        if ((strTeacherUsername.Trim() == "") || (strTeacherPassword.Trim() == "") || (strTeacherNickname.Trim() == "") || (strTeacherEmail.Trim() == ""))
            {
            Snackbar.Add($"fill in blanks", Severity.Warning, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
