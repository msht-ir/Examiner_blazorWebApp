@page "/T_ReportExamPoints"
@using ExaminerB.Service
@using Microsoft.VisualBasic
@inject FeService feService
@inject NavigationManager Navman
@inject AppState appState
@inject IJSRuntime JS
@implements IDisposable
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@if (!_hasFetched)
    {
    <_ScanSheets />
    }
else
    {
    //Page-Header
        <div style="text-align:center; padding:10px;">
        <h6 style="color:gray;">@course.CourseName</h6>
        <h5 style="color:royalblue"><span style="color:darkgray;font-style:italic;">Exam </span>@exam.ExamTitle</h5>
        <h6>@exam.ExamDateTime <span style="font-size:small;color:indianred"> /@exam.ExamDuration min </span><span style="font-size:small;color:gray"> /students: @lstStudentsExams.Count</span></h6>
        </div>
    <hr />
        <div style="text-align:center">
            <button class="btn btn-link" type="submit" @onclick="BtnBack">
            <img src="/img/icoBack3.png" width="40" />
            </button>
            <button class="btn btn-link align-items-center" Title="inject a message to exam session ارسال پيام به جلسه امتحان" @onclick="SendMessageToExamStudents">
            <img src="/img/icoNewNote3.png" width="30" />
            </button>
            <button class="btn btn-link align-items-center" Title="delete injected messages to exam session حذف پيام هاي ارسال شده به جلسه امتحان" @onclick="ClearMessagesInjectedToExamSession">
            <img src="/img/icoEraser.png" width="30" />
            </button>
            <button class="btn btn-link align-items-center" Title="refresh بروز رساني" @onclick="RefreshPageData">
            <img src="/img/gifUserLogin.gif" width="36" />
            </button>
            <button class="btn btn-link pulse-hover" type="submit" @onclick="BtnReportPointsPlain">
            <img src="/img/icoListP.png" width="42" title="جدول نمرات دانشجويان" />
            </button>
        </div>
        <EditForm Model="lstStudentsExams" style="max-width:600px; margin: 0 auto;">
        @if (_cmd == "sendmessagetoexamstudents")
            {
            <hr />
            <h6 style="text-align:center;font-weight:bold; padding-bottom:10px;color:indianred">Send a short message ارسال پيام به جلسه امتحان</h6>
                <div class="d-flex mb-3" style="max-width:600px; margin: 0 auto;">
                <MudTextField ref="refNewExamTitle"
                              @bind-Value="_txtNewExamSessionNote"
                              Label=""
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Autocomplete="off"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Send"
                              OnAdornmentClick="BtnInjectMessageToExamSession"
                              Style="font-family:tahoma;margin-left:20px;margin-right:20px;"
                              Lines="2"
                              Class="my-textfield" />
                    <button class="btn btn-link" name="btnNewCourse" @onclick="BtnCancel">
                    <img src="/img/icoCancel.png" width="20" />
                    </button>
                </div>
            }
        @if (_cmd == "listexamstudentsmessages")
            {

            }
            @{
            i = 0;
            }
        @foreach (var studentExam in lstStudentsExams)
            {
            i++;
                <div class="container mt-2">
                    <div class="card">
                        <div class="card-body" style="background-color:whitesmoke">
                            <div style="font-weight:bold;">
                                <button class="btn btn-link" Title="student folder فولدر دانشجو" @onclick='() => BtnReportStudent(studentExam.StudentId)'>
                                <img src="/img/icoFolderS.png" width="22" />
                                </button>
                            @i: @studentExam.StudentName - @studentExam.StudentNickname
                            <hr />
                            </div>
                            <div style="font-weight:normal;">
                            @* <img src="/img/icoReport0.png" width="20" /> *@
                            <span style="color:green">start: </span> <span style="font-size:small">@PersianDate(studentExam.StartDateTime)</span> /
                            <span style="color:royalblue">finish: </span> <span style="font-size:small">@PersianDate(studentExam.FinishDateTime)</span>
                            </div>
                            <div style="display:flex; align-items:center;font-weight:bold;">
                                <button class="btn btn-link" @onclick="async () => await BtnShowStudentExamTests(studentExam)">
                                <img src="/img/icoListT.png" width="28" />
                                </button>
                            @if (studentExam.StudentExamPoint < 10)
                                {
                                <span style="color:red">@(Math.Abs(studentExam.StudentExamPoint).ToString("F2"))</span> <span style="font-size:x-small;color:dimgray"> /20</span>
                                }
                            else if (studentExam.StudentExamPoint < 17)
                                {
                                <span style="color:royalblue">@(Math.Abs(studentExam.StudentExamPoint).ToString("F2"))</span> <span style="font-size:x-small;color:dimgray"> /20</span>
                                }
                            else
                                {
                                <span style="color:darkgoldenrod">@(Math.Abs(studentExam.StudentExamPoint).ToString("F2"))</span> <span style="font-size:x-small;color:dimgray"> /20</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
            <div style="text-align: center;">
                <button class="btn btn-link" type="submit" @onclick="BtnBack">
                <img src="/img/icoBack3.png" width="40" />
                </button>
            </div>
        </EditForm>
    }
    <script>
    window.scrollToTop = () => { window.scrollTo({ top: 0, behavior: 'smooth' }); };
    </script>

@code {
    public bool _hasFetched = false;
    public List<User> lstStudents = new List<User>();
    List<StudentExam> lstStudentsExams = new List<StudentExam>();
    User user = new User();
    Course course = new Course();
    Exam exam = new Exam();
    int i = 0;
    public int nStudents = 0;
    public int nStudentsStarted = 0;
    public int nStudentsFinished = 0;
    public int TotalPoints = 0;
    private string _cmd = "";
    private string _txtNewExamSessionNote = "";

    //LifeCycleEvents
    protected override async Task OnInitializedAsync ()
        {
        appState.OnChange += TriggerRender;
        if (Convert.ToInt32(appState.UserLoginStatus) != 1)
            {
            Navman.NavigateTo("/Login");
            }
        await RefreshPageData();
        _hasFetched = true;
        }
    private void TriggerRender ()
        {
        InvokeAsync(StateHasChanged);
        }
    public void Dispose ()
        {
        appState.OnChange -= TriggerRender;
        }
    //btns
    public void BtnShowAnswers ()
        {
        string _appstatecmd = appState.Cmd ?? "";
        _appstatecmd = (_appstatecmd.EndsWith("raw")) ? (Strings.Left(_appstatecmd, _appstatecmd.Length - 3)) : (_appstatecmd + "raw");
        appState.SetCmd(_appstatecmd);
        i = 0;
        }
    public async Task BtnShowStudentExamTests (StudentExam studentExam)
        {
        appState.SetCmd("studentexamtests"); //{studentexamtests|studentcoursetests}
        appState.SetStudentExamId(studentExam.StudentExamId);
        appState.SetStudentName(studentExam.StudentName);
        appState.SetStudentNickname(studentExam.StudentNickname);
        Navman.NavigateTo("/T_ReportTests");
        }
    public void BtnReportPointsPlain ()
        {
        Navman.NavigateTo("/T_ReportExamPoints_plain");
        }
    //convert date
    public string PersianDate (string? dt)
        {
        // notices: 1-this mthod must be synchronus. 2- for miladi dates, simply discard this methos in html above
        if ((Convert.ToInt32(appState.UserTags) & 256) == 256)
            {
            return feService.ToPersianDate(dt);
            }
        else
            {
            return dt;
            }
        }
    //method
    private void SendMessageToExamStudents ()
        {
        _cmd = "sendmessagetoexamstudents";
        StateHasChanged();
        }
    public async Task BtnInjectMessageToExamSession ()
        {
        exam.ExamId = Convert.ToInt32(appState.ExamId);
        if (_txtNewExamSessionNote.Trim().Length < 5)
            {
            Snackbar.Add($"type a message of at least 5 chars", Severity.Warning, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
            }
        else
            {
            @foreach (var studentExam in lstStudentsExams)
                {
                //ReferenceTypes 1:quicknote(s) 2:SectNote(s) 11:quicknote(t) 12:SectNote(t) 13:StudentNote(t) 14:GroupNote(t) 15:CourseNote(t) 16:ExamNote(t) 17:StudentExamNote(t)
                Note note = new Note();
                note.ReferenceId = studentExam.StudentExamId;
                note.ReferenceType = 17;
                note.NoteDateTime = DateTime.Now.ToString("yyyy-MM-dd HH:mm");
                note.NoteText = _txtNewExamSessionNote;
                note.CreatorId = Convert.ToInt32 (appState.UserId);
                int result = await feService.Create_Note(note);
                }
            Snackbar.Add($"message injected to Exam Session", Severity.Info, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
            _txtNewExamSessionNote = "";
            _cmd = "";
            await RefreshPageData(); //just to refresh page data
            StateHasChanged();
            }
        }
    private async Task ClearMessagesInjectedToExamSession ()
        {
        var message = new MarkupString($"<hr><span style='color:indianred'>Clear</span> injected messages to this exam session?<br><br><div style='text-align:center'><img src='/img/icoEraser.png' width='70'/></div><br><hr>");
        bool? confirmResult = await DialogService.ShowMessageBox(title: "Confirm", markupMessage: message, yesText: "Yes", cancelText: "No");
        if (confirmResult == true)
            {
            @foreach (var studentExam in lstStudentsExams)
                {
                bool result = await feService.Delete_Notes(studentExam.StudentExamId, 17);
                }
            Snackbar.Add($"injected messages cleared", Severity.Warning, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
            StateHasChanged();
            }
        }
    public async Task RefreshPageData ()
        {
        exam.ExamId = Convert.ToInt32(appState.ExamId);
        _hasFetched = false;
        exam = await feService.Read_Exam(exam.ExamId, true);
        lstStudentsExams.Clear();
        lstStudentsExams = await feService.Read_StudentExams("ByExamId", Convert.ToInt32(appState.ExamId), 0);
        if (lstStudentsExams.Count > 0)
            {
            exam.ExamDateTime = lstStudentsExams [0].ExamDateTime;
            exam.ExamTitle = lstStudentsExams [0].ExamTitle;
            exam.ExamDuration = lstStudentsExams [0].ExamDuration;
            course.CourseName = lstStudentsExams [0].CourseName;
            //SHOW TIME
            DateTime _examDateTimeStart = DateTime.ParseExact(exam.ExamDateTime, "yyyy-MM-dd HH:mm", System.Globalization.CultureInfo.InvariantCulture);
            DateTime _examDateTimeFinish = _examDateTimeStart.AddMinutes(exam.ExamDuration);
            if (DateTime.Now > _examDateTimeFinish)
                {
                //exam has finished
                Snackbar.Add($"exam is finished", Severity.Error, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
                }
            else if (DateTime.Now < _examDateTimeStart)
                {
                //exam has not started yet
                TimeSpan diff = _examDateTimeStart - DateTime.Now;
                int hours = (int) diff.TotalHours;
                int minutes = diff.Minutes;
                Snackbar.Add($"{hours} hr  {minutes + 1} min (to start)", Severity.Success, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
                }
            else
                {
                //exam is running
                TimeSpan _ts = _examDateTimeFinish - DateTime.Now;
                if (DateTime.Now > _examDateTimeFinish.AddMinutes(-3))
                    {
                    Snackbar.Add($"{_ts.Hours:D2} : {_ts.Minutes:D2} : {_ts.Seconds:D2} (to finish)", Severity.Warning, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
                    }
                else
                    {
                    Snackbar.Add($"  {_ts.Hours:D2} : {_ts.Minutes:D2} : {_ts.Seconds:D2} (to finish)", Severity.Info, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
                    }
                }
            }
        else
            {
            //needs: @inject ISnackbar Snackbar --at top of page
            Snackbar.Add("students list is empty", Severity.Warning, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
            //--old code was: await JS.InvokeVoidAsync ("alert", "List of Students (for this Exam) is Empty!");
            BtnBack();
            }
        _hasFetched = true;
        }
    public async Task BtnReportStudent (int studentId)
        {
        if (studentId > 0)
            {
            appState.SetReturnPage("/T_ReportExamPoints");
            Navman.NavigateTo($"/T_ReportStudents/S/{studentId}");
            }
        }
    private void BtnCancel ()
        {
        _cmd = "";
        StateHasChanged();
        }
    public void BtnBack ()
        {
        if (appState.ReturnPage != "/T_ReportTests")
            {
            Navman.NavigateTo(appState.ReturnPage ?? "/Login");
            }
        else
            {
            Navman.NavigateTo("/T_Courses");
            }
        }
    }
