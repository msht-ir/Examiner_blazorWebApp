@using System.Globalization
@using System.Reflection
@inject FeService feService
@inject AppState appState;
@inject NavigationManager Navman
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@if (IsOpen)
    {
    Title = "Chatroom " + appState.SelectedChatroomName;
    <div class="modal-backdrop fade show"></div>
    <div class="modal show d-block">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button class="btn btn-link" @onclick="BtnCancel">
                        <img src="/img/icoBack3.png" width="32" title="Back" />
                    </button>
                    <button class="btn btn-link" @onclick="ReadChatroomPosts">
                        <img src="/img/gifUserLogin.gif" width="32" title="Refresh" />
                    </button>
                    <button class="btn btn-link" @onclick="BtnChangeFontSize">
                        <img src="/img/icoFontAa.png" title="Font Size  تغيير انداز فونت" alt="FontSize" width="28" />
                    </button>
                </div>
                <div class="modal-body">
                    <div style="text-align:center">
                        chatroom: <span style="color:royalblue;">@appState.SelectedChatroomName</span>
                        <hr />
                    </div>
                    @if (_cmd == "AddNewChatroomPost")
                        {
                        <div class="mt-3">
                            <MudContainer MaxWidth="MaxWidth.Small" Class="mt-2 px-0">
                                <MudCard Class="mx-0">
                                    <MudCardContent Style="background-color:whitesmoke;">
                                        <MudTextField T="string" Label="type here" @bind-Value="chatroomPost.PostText" Variant="Variant.Text" Lines="8" AutoResize="true" Style="width:100%;font-family:'Courier New', Courier, monospace" />
                                            <br />
                                            <div style="text-align:center">
                                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Margin="Margin.Dense" @onclick="BtnInsertChatroomPost">Post</MudButton>
                                                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Margin="Margin.Dense" @onclick="BtnCancelNewChat">Cancel</MudButton>
                                            </div>
                                    </MudCardContent>
                                </MudCard>
                            </MudContainer>
                        </div>                        
                        }
                    else
                        {
                        <div style="text-align:center">
                            <button class="btn btn-link" @onclick="BtnCreateChatroomPost">
                                <img src="/img/icoAdd0.png" width="22" title="new post" />
                            </button>
                        </div>                        
                        }
                    @foreach (ChatroomPost chatroomPost in lstChatroomPosts)
                        {
                        <div class="mt-3">
                            <MudContainer Class="mt-2 px-0">
                                <MudCard Class="mx-0" elevation="2">
                                    <MudCardContent Style="background-color: rgba(250,250,250);">
                                        @if ((_cmd == "EditChatroomPost") && (appState.SelectedChatroomPostId == chatroomPost.ChatroomPostId))
                                            {
                                            <div class="mt-3">
                                                <MudContainer MaxWidth="MaxWidth.Small" Class="mt-2 px-0">
                                                    <MudCard Class="mx-0">
                                                        <MudCardContent Style="background-color:whitesmoke;">
                                                            <MudTextField T="string" Label="edit:" @bind-Value="chatroomPost.PostText" Variant="Variant.Text" Lines="8" AutoResize="true" Style="width:100%;font-family:'Courier New', Courier, monospace" />
                                                                <br />
                                                                <div style="text-align:center">
                                                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Margin="Margin.Dense" @onclick="()=>BtnUpdateChatroomPost(chatroomPost)">Update</MudButton>
                                                                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Margin="Margin.Dense" @onclick="BtnCancelNewChat">Cancel</MudButton>
                                                                </div>
                                                        </MudCardContent>
                                                    </MudCard>
                                                </MudContainer>
                                            </div>                        
                                            
                                            }
                                        else
                                            {
                                            @if((chatroomPost.PostTags & 2) == 2)
                                                {
                                                <div style="font-size:smaller;font-style:italic;color:gray;">--- edited post ---</div>
                                                }
                                            <div class="d-flex align-items-center" style="font-size:smaller; font-weight:bold;color:indianred;">
                                                @chatroomPost.PostDateTime
                                            </div>
                                            <div class="d-flex align-items-center" style="font-size:smaller; font-weight:bold;color:royalblue;">
                                                @chatroomPost.SenderName
                                            </div>
                                            <div style='white-space: pre-wrap;font-size:small; font-weight:normal;color:black;padding-left:10px;font-size:@(_cmd == "UseLargeFontSize" ? "large" : "small")'> @chatroomPost.PostText.Trim()</div>
                                            @if (chatroomPost.SenderId == student.UserId)
                                                {
                                                <hr />
                                                <div style="text-align:left">
                                                    <button class="btn btn-link" @onclick="()=>BtnEditChatroomPost(chatroomPost.ChatroomPostId)">
                                                        <img src="/img/icoRename.png" width="28" title="edit post" />
                                                    </button>
                                                    <button class="btn btn-link" @onclick="()=>BtnDeleteChatroomPost(chatroomPost.ChatroomPostId)">
                                                        <img src="/img/icoDelete1.png" width="20" title="delete post" />
                                                    </button>
                                                </div>
                                                }
                                            }
                                    </MudCardContent>
                                </MudCard>
                            </MudContainer>
                        </div>
                        } 
                    @if (lstChatroomPosts.Count > 0)
                        {
                        <br />
                        <br />
                        <br />
                        <div style="text-align:center">
                            <button class="btn btn-link" @onclick="BtnCancel">
                                <img src="/img/icoBack3.png" width="35" title="Back" />
                            </button>
                            <button class="btn btn-link" @onclick="BtnChangeFontSize">
                                <img src="/img/icoFontAa.png" title="Font Size  تغيير انداز فونت" alt="FontSize" width="28"/>
                            </button>
                        </div>                        
                        }
                </div>
            </div>
        </div>
    </div>
    }

@code {
    [Parameter] public string Title { get; set; }
    [Parameter] public RenderFragment ChildContent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    ChatroomPost chatroomPost = new ChatroomPost ();
    string _cmd = "";
    bool _hasFetched;
    public bool IsOpen { get; set; } = true;
    int chatroomId = 0;
    int studentId = 0;
    User student = new User ();
    private MudTextField<string> reftxtSearch;
    private string chatroomPostText="";
    public List<ChatroomPost> lstChatroomPosts = new List<ChatroomPost> ();
    private bool hasScrolled = false;
    bool _help;

    //LifeCycleEvents
    protected override async Task OnInitializedAsync()
        {
        appState.OnChange += TriggerRender;
        student.UserId = Convert.ToInt32(appState.UserId);
        if (Convert.ToInt32(appState.UserLoginStatus) != 1)
            {
            Navman.NavigateTo ("/Login");
            }
        await ReadChatroomPosts ();
        _hasFetched = true;
        } 
    private void TriggerRender()
        {
        InvokeAsync(StateHasChanged);
        }
    public void Dispose()
        {
        appState.OnChange -= TriggerRender;
        }
    public void Open() => IsOpen = true;
    private async Task Close()
        {
        if (OnClose.HasDelegate)
            {
            await OnClose.InvokeAsync();
            IsOpen = false;
            }
        }
    public async Task BtnCreateChatroomPost()
        {
        chatroomPost.PostText = "";
        _cmd = "AddNewChatroomPost";
        StateHasChanged ();
        }
    public async Task BtnInsertChatroomPost()
        {
        if(chatroomPost.PostText != "")
            {
            chatroomPost.ChatroomId = Convert.ToInt32(appState.SelectedChatroomId);
            chatroomPost.SenderId = student.UserId;
            chatroomPost.PostDateTime = DateTime.Now.ToString("yyyy-MM-dd HH:mm");
            int result = await feService.Create_ChatroomPost(chatroomPost);
            _cmd = "";
            await ReadChatroomPosts ();
            StateHasChanged ();
            }
        }
    public async Task BtnUpdateChatroomPost (ChatroomPost post)
        {
        if (post.PostText != "")
            {
            bool result = await feService.Update_ChatroomPost(post);
            _cmd = "";
            await ReadChatroomPosts ();
            StateHasChanged ();
            }
        }
    private async Task BtnChangeFontSize()
        {
        _cmd = (_cmd == "UseLargeFontSize") ? "": "UseLargeFontSize";
        StateHasChanged ();
        }
    public void BtnEditChatroomPost(int chatroomPostId)
        {
        _cmd = "EditChatroomPost";
        appState.SetSelectedChatroomPostId (chatroomPostId);
        StateHasChanged ();
        }
    public async Task BtnDeleteChatroomPost(int chatroomPostId)
    {
        var message = new MarkupString($"<hr>Do you want to <span style='color:indianred'>delete</span> this post?<br><br> <div style='text-align:center'><img src='/img/icoDelete1.png' width='40'/></div><br><hr>");
        bool? confirmResult = await DialogService.ShowMessageBox(title: "Confirm", markupMessage: message, yesText: "Yes", cancelText: "No");
        if (confirmResult == true)
        {
            bool result = await feService.Delete_ChatroomPost (chatroomPostId);
            if(result)
            {
                Snackbar.Add($"deleted", Severity.Info); //Severity.Warning .Error | .Info | .Success --needs: @inject ISnackbar Snackbar
                _hasFetched = false;
                await ReadChatroomPosts ();
                StateHasChanged ();
                _hasFetched = true;
            }
            else
            {
                Snackbar.Add($"failed to delete chat", Severity.Error); //Severity.Warning .Error | .Info | .Success --needs: @inject ISnackbar Snackbar
            }
        }
    }
    public async Task ReadChatroomPosts()
        {
        student.UserId = Convert.ToInt32 (appState.UserId);
        chatroomId = Convert.ToInt32 (appState.SelectedChatroomId);
        lstChatroomPosts.Clear ();
        lstChatroomPosts = await feService.Read_ChatroomPosts(chatroomId);
        StateHasChanged ();
        }
    public void BtnCancelNewChat()
        {
        _cmd = "";
        StateHasChanged ();
        }
    public void BtnCancel()
        {
        appState.SetCmd("");
        Close ();
        }
}
