    private async Task FilterSubprojects (int projectId)
        {
        lstSubprojects.Clear();
        foreach (Project project in lstProjects)
            {
            if (project.ProjectId == projectId)
                {

                lstSubprojects = project.Subprojects;
                return;
                }
            }
        }
    private void BtnReplaceNote (int noteId)
        {
        if (Convert.ToInt32(appState.NoteId) == noteId)
            {
            _cmd = (_cmd == "MoveNoteToNotebook") ? "" : "MoveNoteToNotebook";
            }
        else
            {
            appState.SetNoteId(noteId);
            _cmd = "MoveNoteToNotebook";
            }
        StateHasChanged();
        }
    private async Task BtnMoveToSelectSection (int subprojectId, int noteid)
        {
        if (subprojectId > 0)
            {
            Note _note = new Note { NoteId = noteid, ReferenceType = (appState.UserRole == "teacher" ? 12 : 2), ReferenceId = subprojectId };
            bool result = await feService.Update_NoteParent(_note);
            if (result)
                {
                Snackbar.Add("note replaced", Severity.Success);
                _cmd = "";
                NotebookId = 0;
                SectionId = 0;
                await GetListOfProjects(Convert.ToInt32(appState.UserId), _ShowProjectsMode);
                Subproject _subproj = new Subproject ()
                        {
                        SubprojectId = subprojectId,
                        ProjectId = 0,
                        SubprojectName = "",
                        SubprojectTags = 0,
                        Notes = new List<Note> ()
                        };
                await BtnReadSectionNotes (_subproj);
                StateHasChanged();
                }
            else
                {
                Snackbar.Add("failed", Severity.Warning);
                }
            }
        else
            {
            Snackbar.Add("select notebook and section", Severity.Info, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
            }
        }
    //handle Keys
    private async Task HandleKey_Searchbox (KeyboardEventArgs e)
        {
        if (e.Key == "Enter")
            {
            await BtnReadNotesBySearch();
            return;
            }
        if (e.Key == "Escape")
            {
            strSearchKey = "";
            await InvokeAsync(StateHasChanged);
            await refSearchNote.FocusAsync();
            }
        }
    //convert date
    public string PersianDate (string? dt)
        {
        // notices: 1-this mthod must be synchronus. 2- for miladi dates, simply discard this methos in html above
        if ((Convert.ToInt32(appState.UserTags) & 256) == 256)
            {
            return feService.ToPersianDate(dt);
            }
        else
            {
            return dt;
            }
        }
