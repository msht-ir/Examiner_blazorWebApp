    private async Task HandleModalClose ()
        {
        int userId = Convert.ToInt32(appState.UserId);
        await GetListOfProjects(userId, _ShowProjectsMode);
        Subproject _subProject = new Subproject() { SubprojectId = Convert.ToInt32(appState.NoteReferenceId), ProjectId = Convert.ToInt32(appState.ProjectId) };
        await BtnReadSectionNotes(_subProject);
        if (lstSearchedtNotes.Count > 0)
            {
            //refresh searched notes, as one of them may be editted
            await BtnReadNotesBySearch();
            }
        StateHasChanged();
        }
