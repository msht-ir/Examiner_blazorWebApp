@page "/E_NoteBooks"
@using ClosedXML.Excel
@using Microsoft.Extensions.Hosting
@using ClosedXML
@using ExaminerB.Service
@inject NavigationManager Navman
@inject AppState appState
@inject FeService feService
@inject IJSRuntime JS
@implements IDisposable
@using System.Globalization
@using System.Reflection
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@if (!_hasFetched)
    {
    <_LoadingTimer />
    }
else if (appState.Cmd == "CreateNote")
    {
    <Modal_CreateNote OnClose="HandleModalClose" />
    }
else if (appState.Cmd == "ShowNoteInDialog")
    {
    <Modal_ShowNote OnClose="HandleModalClose" />
    }
else if (appState.Cmd == "UpdateNote")
    {
    <Modal_CreateNote OnClose="HandleModalClose" />
    }
else
    {
    <div style="font-size:larger; text-align:center;color:black">@appState.UserNickname</div>
        <div style="text-align:left; max-width:500px; margin: 0 auto;">
            <button class="btn btn-link" @onclick="() => BtnBackToCallingPage()">
            <img src="/img/icoBack3.png" style="width:40px" title="back" />
            </button>
        @if (appState.UserRole == "teacher")
            {
                <button class="btn btn-link" @onclick="() => BtnGotoReportUserNotes()">
                <img src="/img/icoNoteReport.png" style="width:35px" title="goto: quick notes" />
                </button>
                <button class="btn btn-link pulse-animation" @onclick="CreateQuickNote">
                <img src="/img/icoNewNote3.png" width="28" title="add new quick-note" />
                </button>
            }
        </div>
        <EditForm Model="lstProjects">
        @* SEARCH BOX *@
            <MudContainer MaxWidth="MaxWidth.Small" Class="mt-2 px-0" style="max-width:500px; margin: 0 auto;">
                <MudCard Class="mx-0">
                    <MudCardContent Style="background-color:whitesmoke;">
                        <div class="mb-3" style="max-width:500px; margin:0 auto">
                            <div class="d-flex align-items-center mb-3">
                            <MudTextField T="string"
                                          @ref="refSearchNote"
                                          @bind-Value="strSearchKey"
                                          OnKeyDown="HandleKey_Searchbox"
                                          Label="Search"
                                          Variant="Variant.Text"
                                          Margin="Margin.Dense"
                                          Immediate="true"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          OnAdornmentClick="BtnReadNotesBySearch"
                                          Class="my-textfield" />
                            @if (lstSearchedtNotes.Count > 0)
                                {
                                    <button class="btn btn-link" @onclick="BtnCancelSearch">
                                    <img src="/img/icoCancel.png" width="20" title="cancel search" style="margin-left:20px;margin-top:15px;"/>
                                    </button>
                                }
                            </div>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudContainer>
        @if (lstSearchedtNotes.Count > 0)
            {
            @* 1 SEARCH-RESULTS *@
            <h5 style="text-align:center; margin-top:10px;">top 20 results</h5>
            foreach (Note note in lstSearchedtNotes)
                {
                    <div>
                    @if ((note.NoteTags & 1) == 1)
                        {
                        @* 1.1 SEARCH-RESULTS -- RTL *@
                            <div class="d-flex" style="text-align:center; color:indianred; font-weight:bold;font-size:small">
                                <MudContainer MaxWidth="MaxWidth.Small" Class="mt-2 px-0" style="max-width:500px; margin: 0 auto;">
                                    <MudCard Class="mx-0">
                                        <MudCardContent Style="background-color:whitesmoke;">
                                        <span style="color:indianred; font-weight:bold;">@note.NoteDateTime</span>
                                        <p style="color:gray;font-weight:normal;font-style:italic">@note.ReferenceName</p>
                                        <hr />
                                        @if (note.NoteText.Length > 100)
                                            {
                                                <div style="white-space: pre-wrap; font-family:Courier New, Courier, monospace;font-size:small;color:black;">
                                                @note.NoteText.Substring(0, 100) <span style="font-size:xx-small;font-weight:bold;color:indianred">[...]</span>
                                                </div>
                                            }
                                        else
                                            {
                                                <div style="white-space: pre-wrap; font-family:Courier New, Courier, monospace;font-size:small;color:black;">
                                                @note.NoteText
                                                </div>
                                            }
                                        <hr />
                                            <div class="d-flex align-items-center" style="color:indianred; font-weight:bold;font-size:small">
                                                <MudMenu Label="actions" Variant="Variant.Outlined" Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.Menu" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Dense="true">
                                                    <MudMenuItem @onclick="() => BtnEditNoteInDialog(note)">
                                                        <button class="btn btn-link pulse-animation">
                                                        <img src="/img/icoRename.png" width="28" />
                                                        </button>
                                                    edit note
                                                    </MudMenuItem>
                                                    <MudMenuItem @onclick="() => BtnDeleteNote(note)">
                                                        <button class="btn btn-link">
                                                        <img src="/img/icoDelete1.png" width="20" title="delete note" />
                                                        </button>
                                                    delete note
                                                    </MudMenuItem>
                                                </MudMenu>
                                            @if (note.NoteText.Length > 100)
                                                {
                                                    <button class="btn btn-link pulse-animation" @onclick="() => BtnShowNoteInDialog(note)">
                                                    <img src="/img/icoNoteReport.png" width="24" title="show note expanded" />
                                                    </button>
                                                }
                                            </div>
                                        </MudCardContent>
                                    </MudCard>
                                </MudContainer>
                            </div>
                        }
                    else
                        {
                        @* 1.2 SEARCH-RESULTS -- LTR *@
                            <div class="d-flex" style="color:indianred; font-weight:bold;font-size:small">
                                <MudContainer MaxWidth="MaxWidth.Small" Class="mt-2 px-0" style="max-width:500px; margin: 0 auto;">
                                    <MudCard Class="mx-0">
                                        <MudCardContent Style="background-color:whitesmoke;">
                                        <span style="color:indianred; font-weight:bold;">@note.NoteDateTime</span>
                                        <p style="color:gray;font-weight:normal;font-style:italic">@note.ReferenceName</p>
                                        <hr />
                                        @if (note.NoteText.Length > 100)
                                            {
                                                <div style="white-space: pre-wrap; font-family:Courier New, Courier, monospace;font-size:small;color:black;">
                                                @note.NoteText.Substring(0, 100) <span style="font-size:xx-small;font-weight:bold;color:indianred">[...]</span>
                                                </div>
                                            }
                                        else
                                            {
                                                <div style="white-space: pre-wrap; font-family:Courier New, Courier, monospace;font-size:small;color:black;">
                                                @note.NoteText
                                                </div>
                                            }
                                        <hr />
                                            <div class="d-flex align-items-center" style="color:indianred; font-weight:bold;font-size:small">
                                                <MudMenu Label="actions" Variant="Variant.Outlined" Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.Menu" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Dense="true">
                                                    <MudMenuItem @onclick="() => BtnEditNoteInDialog(note)">
                                                        <button class="btn btn-link pulse-animation">
                                                        <img src="/img/icoRename.png" width="28" />
                                                        </button>
                                                    edit note
                                                    </MudMenuItem>
                                                    <MudMenuItem @onclick="() => BtnDeleteNote(note)">
                                                        <button class="btn btn-link">
                                                        <img src="/img/icoDelete1.png" width="20" title="delete note" />
                                                        </button>
                                                    delete note
                                                    </MudMenuItem>
                                                </MudMenu>
                                            @if (note.NoteText.Length > 100)
                                                {
                                                    <button class="btn btn-link pulse-animation" @onclick="() => BtnShowNoteInDialog(note)">
                                                    <img src="/img/icoNoteReport.png" width="24" title="show note expanded" />
                                                    </button>
                                                }
                                            </div>
                                        </MudCardContent>
                                    </MudCard>
                                </MudContainer>
                            </div>
                        }
                    </div>
                }
            }
        else
            {
                <div class="d-flex justify-content-center align-items-center mb-1" style="text-align:center">
                    <button class="btn btn-link" @onclick="BtnToggleShowProjectsMode">
                    <img src="/img/icoListP.png" width="34" title="toggle: active / non-active / all-notes" />
                    </button>
                    <span style="font-size:large;text-align:center;color:indianred; margin:10px;">
                    @(_ShowProjectsMode switch
                        {
                            "all" => "all notebooks",
                            "active" => "active notebooks",
                            "inactive" => "inactive notebooks",
                            _ => ""
                            })
                    </span>
                </div>
            @* 2 NOTEBOOKS and SECTIONS *@
                <div class="accordion" id="accordionProjects" style="max-width:500px; margin: 0 auto;">
                @* 2.1 NOTEBOOKS *@
                @foreach (Project project in lstProjects)
                    {
                    var collapseId = $"collapse{project.ProjectId}";
                    _clpsP = ((appState.ProjectId) != project.ProjectId) ? "collapse" : "collapse show";
                        <div class="accordion-item mb-1">
                            <h4 class="accordion-header" style="background-color:rgba(252,252,252)">
                                <button class="accordion-button collapsed"
                                    style="background-color:rgba(245,245,245)"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId"
                                    aria-expanded="true"
                                    aria-controls="@collapseId">
                                    <button class="btn btn-link" @onclick="() => BtnReadNotebookNotes(project)">
                                    <img class="pulse-hover" src="img/icoNoteBook.png" width="38" style="margin-right:10px;" />
                                    </button>
                                <h3 style="color:indigo">@project.ProjectName</h3>
                                </button>
                            </h4>
                            <div id="@collapseId" class="accordion-collapse @_clpsP" data-bs-parent="#accordionProjects">
                                <div class="accordion-body" style="background-color:rgba(250,250,250)">
                                    <div id="T1">
                                    @if ((appState.Cmd == "EditProject") && (appState.ProjectId == project.ProjectId))
                                        {
                                        string btnProjectId = "btnProjectName";
                                            <div class="d-flex mb-3">
                                            <MudTextField @ref="refProjectName"
                                                          @bind-Value="project.ProjectName"
                                                          Label="notebook"
                                                          Variant="Variant.Text"
                                                          Margin="Margin.Dense"
                                                          Autocomplete="off"
                                                          Adornment="Adornment.End"
                                                          AdornmentIcon="@Icons.Material.Filled.Save"
                                                          OnAdornmentClick="() => BtnUpdateProject(project)"
                                                          Style="font-family:tahoma;"
                                                          Class="my-textfield" />
                                            </div>
                                            <div class="d-flex mb-2">
                                            <MudCheckBox @bind-Value="project.IsActive" Label="active" Color="Color.Primary"></MudCheckBox>
                                                <button class="btn btn-link" style="margin-left:15px;" @onclick="() => BtnDeleteProject(project.ProjectId)" @key="project.ProjectId">
                                                <img src="/img/icoDelete1.png" width="25" title="delete notebook" />
                                                </button>
                                                <button class="btn btn-link" style="margin-left:15px;" name="btnNewCourse" @onclick="BtnCancel">
                                                <img src="/img/icoCancel.png" width="24" title="cancel" />
                                                </button>
                                            </div>
                                        }
                                    else
                                        {
                                            <div style="text-align: center;">
                                                <button class="btn btn-link" @onclick="() => BtnAddNewSubproject(project.ProjectId)">
                                                <img src="/img/icoAddSection1.png" width="28" title="add new section" />
                                                </button>
                                                <button class="btn btn-link" type="button" @onclick="() => BtnEditProject(project.ProjectId)">
                                                <img src="/img/icoRename.png" width="34" title="edit notebook" />
                                                </button>
                                            <hr style="color:red" />
                                            </div>
                                        @if ((appState.Cmd == "AddNewSubproject") && (appState.ProjectId == project.ProjectId))
                                            {
                                                <div>
                                                    <div class="d-flex mb-3">
                                                    <MudTextField @ref="refNewSubproject"
                                                                  @bind-Value="txtNewSubprojectTitle"
                                                                  Label="new section"
                                                                  Variant="Variant.Text"
                                                                  Margin="Margin.Dense"
                                                                  Autocomplete="off"
                                                                  Adornment="Adornment.End"
                                                                  AdornmentIcon="@Icons.Material.Filled.Save"
                                                                  OnAdornmentClick="() => BtnSaveNewSubproject(project.ProjectId)"
                                                                  Style="font-family:tahoma;"
                                                                  Class="my-textfield" />
                                                        <button class="btn btn-link" name="btnNewCourse" style="margin-left:20px;" @onclick="BtnCancel">
                                                        <img src="/img/icoCancel.png" width="20" title="cancel" style="margin-top:15px;"/>
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        else
                                            {
                                            @* 2.2 SECTIONS *@
                                                <div class="accordion" id="accordionSubprojects-@project.ProjectId">
                                                @foreach (Subproject subProject in project.Subprojects)
                                                    {
                                                    var collapseId2 = $"collapse{subProject.SubprojectId}";
                                                    _clpsSP = (appState.NoteReferenceId != subProject.SubprojectId) ? "collapse" : "collapse show";
                                                        <div class="accordion-item mb-1">
                                                            <h4 class="accordion-header">
                                                                <button class="accordion-button collapsed"
                                                                    type="button"
                                                                    data-bs-toggle="collapse"
                                                                    data-bs-target="#@collapseId2"
                                                                    aria-expanded="true"
                                                                    aria-controls="@collapseId2" @onclick="() => BtnReadSectionNotes(subProject)">
                                                                    <button class="btn btn-link">
                                                                    <img class="pulse-animation" src="img/icoBookmark1.png" width="22" style="margin-right:5px;" />
                                                                    </button>
                                                                <h6 style="margin-left:5px;">@subProject.SubprojectName</h6>
                                                                </button>
                                                            </h4>
                                                            <div id="@collapseId2" class="accordion-collapse @_clpsSP" data-bs-parent="#accordionSubprojects-@project.ProjectId">
                                                                <div class="accordion-body" style="background-color:rgba(252,252,252)">
                                                                @if ((appState.Cmd == "EditSubproject") && (appState.SubprojectId == subProject.SubprojectId))
                                                                    {
                                                                    @* EDIT SECTION *@
                                                                        <div class="d-flex mb-1">
                                                                        <MudTextField @ref="refSubprojectName"
                                                                                      @bind-Value="subProject.SubprojectName"
                                                                                      Label="section"
                                                                                      Variant="Variant.Text"
                                                                                      Margin="Margin.Dense"
                                                                                      Autocomplete="off"
                                                                                      Adornment="Adornment.End"
                                                                                      AdornmentIcon="@Icons.Material.Filled.Save"
                                                                                      OnAdornmentClick="() => BtnUpdateSubproject(subProject)"
                                                                                      Style="font-family:tahoma;"
                                                                                      Class="my-textfield" />
                                                                            <button class="btn btn-link" @onclick="() => BtnDeleteSubproject(subProject)">
                                                                            <img src="/img/icoDelete1.png" width="22" style="margin-left:20px;margin-top:15px;" title="delete section" />
                                                                            </button>
                                                                            <button class="btn btn-link" @onclick="() => BtnCancel()">
                                                                            <img src="/img/icoCancel.png" width="20" title="cancel" style="margin-top:15px;" />
                                                                            </button>
                                                                        </div>
                                                                    }
                                                                else if ((_cmd == "MoveSectionToNotebook") & (Convert.ToInt32(appState.SubprojectId) == subProject.SubprojectId))
                                                                    {
                                                                    @* MOVE SECTION To A NOTEBOOK *@
                                                                        <div class="d-flex justyfy-content-center align-items-center" style="text-align: left;margin-bottom:15px;">
                                                                            <MudSelect T="int"
                                                                                   @ref="refProjects"
                                                                                   Label="move to"
                                                                                   Value="NotebookId"
                                                                                   ValueChanged="OnNotebookChanged"
                                                                                   Class="w-auto my-select"
                                                                                   Variant="Variant.Text"
                                                                                   Margin="Margin.Dense"
                                                                                   Adornment="Adornment.End"
                                                                                   AdornmentIcon="@Icons.Material.Filled.FolderCopy"
                                                                                   OnAdornmentClick="() => BtnSectionMoveToSelectedNotebook(NotebookId, subProject)"
                                                                                   Style="color:royalblue;width:140px;font-size:small;font-family:tahoma;">
                                                                            <MudSelectItem Value="0">Select a Notebook...</MudSelectItem>
                                                                            @foreach (var project in lstProjects)
                                                                                {
                                                                                <MudSelectItem Value="@project.ProjectId">@project.ProjectName</MudSelectItem>
                                                                                }
                                                                            </MudSelect>
                                                                            <button class="btn btn-link" Title="cancel" style="margin-left:20px;" @onclick='() => BtnCancel()'>
                                                                            <img src="/img/icoCancel.png" width="20" />
                                                                            </button>
                                                                        </div>
                                                                    }
                                                                else
                                                                    {
                                                                    @* SECTION BUTTONS *@
                                                                        <div style="text-align:center">
                                                                            <button class="btn btn-link pulse-animation" @onclick="() => BtnCreateNewSubprojectNote(subProject)">
                                                                            <img src="/img/icoNewNote3.png" width="24" title="new note" />
                                                                            </button>
                                                                            <button class="btn btn-link" type="button" @onclick="() => BtnEditSubproject(subProject.SubprojectId)">
                                                                            <img src="/img/icoRename.png" width="30" title="edit section" />
                                                                            </button>
                                                                            <button class="btn btn-link" type="button" @onclick="() => BtnReplaceSection(subProject.SubprojectId)">
                                                                            <img src="/img/icoMoveToNoteBook.png" width="32" title="move section to another notebook" />
                                                                            </button>
                                                                        </div>
                                                                    @* 3 NOTES *@
                                                                    if (subProject.SubprojectId == Convert.ToInt32(appState.NoteReferenceId))
                                                                        {
                                                                        @foreach (Note notex in lstSPNotes)
                                                                            {
                                                                            if ((notex.NoteTags & 1) == 1)
                                                                                {
                                                                                @* 3.1 NOTES - RTL *@
                                                                                    <div class="mt-3 text-end">
                                                                                        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-2 px-0">
                                                                                            <MudCard Class="mx-0">
                                                                                                <MudCardContent Style="background-color:whitesmoke;">
                                                                                                    <div class="d-flex align-items-center" style="text-align:center; color:indianred; font-weight:bold;font-size:small">
                                                                                                    @PersianDate(notex.NoteDateTime)
                                                                                                    </div>
                                                                                                <hr />
                                                                                                @if ((_cmd == "MoveNoteToNotebook") & (Convert.ToInt32(appState.NoteId) == notex.NoteId))
                                                                                                    {
                                                                                                    <h6 style="color:indianred;text-align:center;">replace to:</h6>
                                                                                                    @* COMBO Notebooks *@
                                                                                                        <div class="d-flex">
                                                                                                            <MudSelect T="int"
                                                                                                                   @ref="refProjects"
                                                                                                                   Label="Notebook"
                                                                                                                   Value="NotebookId"
                                                                                                                   ValueChanged="OnNotebookChanged"
                                                                                                                   Class="w-auto my-select"
                                                                                                                   Variant="Variant.Text"
                                                                                                                   Margin="Margin.Dense"
                                                                                                                   Style="color:royalblue;width:140px;font-size:small;">
                                                                                                            <MudSelectItem Value="0">Select a Notebook...</MudSelectItem>
                                                                                                            @foreach (var project in lstProjects)
                                                                                                                {
                                                                                                                <MudSelectItem Value="@project.ProjectId">@project.ProjectName</MudSelectItem>
                                                                                                                }
                                                                                                            </MudSelect>
                                                                                                        </div>
                                                                                                    @* COMBO Sections *@
                                                                                                        <div class="d-flex align-content-center align-items-center align-content-md-center">
                                                                                                            <MudSelect T="int"
                                                                                                                   @ref="refSubprojects"
                                                                                                                   Label="Section"
                                                                                                                   Value="SectionId"
                                                                                                                   ValueChanged="OnSectionChanged"
                                                                                                                   Class="w-auto my-select"
                                                                                                                   Variant="Variant.Text"
                                                                                                                   Margin="Margin.Dense"
                                                                                                                   Adornment="Adornment.End"
                                                                                                                   AdornmentIcon="@Icons.Material.Filled.MoveDown"
                                                                                                                   OnAdornmentClick="() => BtnMoveToSelectSection(SectionId, notex.NoteId)"
                                                                                                                   Style="color:royalblue;width:140px;font-size:small;">
                                                                                                            <MudSelectItem Value="0">Select a Section...</MudSelectItem>
                                                                                                            @foreach (var subproject in lstSubprojects)
                                                                                                                {
                                                                                                                <MudSelectItem Value="@subproject.SubprojectId">@subproject.SubprojectName</MudSelectItem>
                                                                                                                }
                                                                                                            </MudSelect>
                                                                                                            <button class="btn btn-link" Title="cancel" style="margin-left:20px;" @onclick='() => BtnCancel()'>
                                                                                                            <img src="/img/icoCancel.png" width="20" />
                                                                                                            </button>
                                                                                                        </div>
                                                                                                    }
                                                                                                else
                                                                                                    {
                                                                                                        <div style="white-space: pre-wrap; font-weight:normal; font-family:'Segoe UI';font-size:small">
                                                                                                        @if (notex.NoteText.Length > 100)
                                                                                                            {
                                                                                                            <div> @notex.NoteText.Substring(0, 100) <span style="font-size:xx-small;font-weight:bold;color:indianred">[...]</span></div>
                                                                                                            }
                                                                                                        else
                                                                                                            {
                                                                                                            <div style="font-weight:normal;font-family:'Segoe UI'"> @notex.NoteText</div>
                                                                                                            }
                                                                                                        </div>
                                                                                                    <hr>
                                                                                                        <div class="d-flex align-items-center text-start" style="text-align:center; color:indianred; font-weight:bold;font-size:small">
                                                                                                            <MudMenu Label="actions" Variant="Variant.Outlined" Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.Menu" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Dense="true">
                                                                                                                <MudMenuItem @onclick="() => BtnCopyToQuickNotes(notex, subProject.ProjectId)">
                                                                                                                    <button class="btn btn-link">
                                                                                                                    <img src="/img/icoCopyToNoteReport.png" width="26" title="copy to quick note" />
                                                                                                                    </button>
                                                                                                                copy to quick notes
                                                                                                                </MudMenuItem>
                                                                                                            <MudDivider />
                                                                                                                <MudMenuItem @onclick="() => BtnReplaceNote(notex.NoteId)">
                                                                                                                    <button class="btn btn-link">
                                                                                                                    <img src="/img/icoMoveToNoteBook.png" width="32" title="انتقال يادداشت به دفترچه" />
                                                                                                                    </button>
                                                                                                                replace
                                                                                                                </MudMenuItem>
                                                                                                                <MudMenuItem @onclick="() => BtnDeleteNote(notex)">
                                                                                                                    <button class="btn btn-link">
                                                                                                                    <img src="/img/icoDelete1.png" width="22" title="delete note" />
                                                                                                                    </button>
                                                                                                                delete note
                                                                                                                </MudMenuItem>
                                                                                                            </MudMenu>
                                                                                                            <button class="btn btn-link pulse-hover" @onclick="() => BtnEditNoteInDialog(notex)">
                                                                                                            <img src="/img/icoRename.png" width="28" title="edit note" />
                                                                                                            </button>
                                                                                                        @if (notex.NoteText.Length > 100)
                                                                                                            {
                                                                                                                <button class="btn btn-link pulse-animation" @onclick="() => BtnShowNoteInDialog(notex)">
                                                                                                                <img src="/img/icoNoteReport.png" width="22" title="show note expanded" />
                                                                                                                </button>
                                                                                                            }
                                                                                                        </div>
                                                                                                    }
                                                                                                </MudCardContent>
                                                                                            </MudCard>
                                                                                        </MudContainer>
                                                                                    </div>
                                                                                }
                                                                            else
                                                                                {
                                                                                @* 3.2 NOTES - LTR *@
                                                                                    <div class="mt-3 text-start">
                                                                                        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-2 px-0">
                                                                                            <MudCard Class="mx-0">
                                                                                                <MudCardContent Style="background-color:whitesmoke;">
                                                                                                    <div class="d-flex align-items-center" style="color:indianred; font-weight:bold;font-size:small">
                                                                                                    @PersianDate(notex.NoteDateTime)
                                                                                                    </div>
                                                                                                <hr />
