    public async Task BtnCopyToQuickNotes (Note note, int projectId)
        {
        var message = new MarkupString($"<hr><span style='color:DarkGreen'>COPY</span> this note to Quick-Notes?<br><br><div style='text-align:center'><img src='/img/icoCopyToNoteReport.png' width='70'/></div><br><hr>");
        bool? confirmResult = await DialogService.ShowMessageBox(title: "Confirm", markupMessage: message, yesText: "Yes", cancelText: "No");
        if (confirmResult == true)
            {
            //ReferenceTypes 1:quicknote(s) 2:SectNote(s) 11:quicknote(t) 12:SectNote(t) 13:StudentNote(t) 14:GroupNote(t) 15:CourseNote(t) 16:ExamNote(t) 17:StudentExamNote(t)
            appState.SetProjectId(projectId);
            user.UserRole = appState.UserRole;
            Note newNote = new Note()
                {
                NoteId = 1,
                ReferenceId = Convert.ToInt32(appState.UserId),
                ReferenceType = 1,
                NoteDateTime = note.NoteDateTime,
                NoteText = note.NoteText,
                NoteTags = note.NoteTags,
                CreatorId = Convert.ToInt32(appState.UserId)
                };
            newNote.ReferenceType = (appState.UserRole == "teacher") ? 11 : 1;
            if (appState.UserRole == "student")
                {
                newNote.NoteTags |= 16; //16:Student-Note
                }
            _hasFetched = false;
            int result = await feService.Create_Note(newNote);
            if (result > 0)
                {
                Snackbar.Add("note copied to quick-notes", Severity.Info);
                user.UserId = Convert.ToInt32(appState.UserId);
                appState.SetCmd("");
                }
            else
                {
                Snackbar.Add("failed to copy note", Severity.Error, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
                }
            _hasFetched = true;
            }
        }
    public async Task BtnDeleteNote (Note note)
        {
        var message = new MarkupString($"<hr><span style='color:indianred'>Delete</span> this note?<br><br><span style='font-weight:bold'>This note</span> will be <span style='color:indianred'>deleted</span>!<br><br><div style='text-align:center'><img src='/img/icoDelete1.png' width='70'/></div><br><hr>");
        bool? confirmResult = await DialogService.ShowMessageBox(title: "Confirm", markupMessage: message, yesText: "Yes", cancelText: "No");
        if (confirmResult == true)
            {
            appState.SetNoteReferenceId(note.ReferenceId);
            bool result = await feService.Delete_Note(note.NoteId);
            if (result)
                {
                Snackbar.Add($"deleted", Severity.Warning);
                user.UserId = Convert.ToInt32(appState.UserId);
                _hasFetched = false;
                await GetListOfProjects(user.UserId, _ShowProjectsMode);
                Subproject _subProject = new Subproject() { SubprojectId = Convert.ToInt32(note.ReferenceId), ProjectId = Convert.ToInt32(appState.ProjectId) };
                await BtnReadSectionNotes(_subProject);
                _hasFetched = true;
                StateHasChanged();
                }
            else
                {
                Snackbar.Add($"failed to delete note", Severity.Error, opt => { opt.VisibleStateDuration = 1500; opt.ShowTransitionDuration = 300; opt.HideTransitionDuration = 300; });
                }
            }
        }
