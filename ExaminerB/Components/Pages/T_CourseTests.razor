    function showLoading() {
        document.getElementById("loadingOverlay").style.display = "block";
        document.querySelectorAll("button").forEach(btn => btn.disabled = true);
    }
    </script>
    <script>
    document.getElementById("txtSearch").focus();
    </script>
    <script>
    window.addEventListener('load', () => {window.scrollTo({ top: 0, behavior: 'smooth' });});
    </script>

@code {
    IBrowserFile? excelFile;
    MemoryStream stream = new MemoryStream();
    private MudAutocomplete<int> refCourseTopics;
    private MudSelect<string> refWorksheets;
    private MudNumericField<int> refPageNumber;
    private MudTextField<string> txtSearch;
    List<string> lstWorksheets = new List<string>();
    List<Test> lstCourseTests = new List<Test>();
    List<Exam> lstExams = new List<Exam>();
    List<StudentExamTest> lstxTests = new List<StudentExamTest>();
    List<CourseTopic> lstCourseTopics = new List<CourseTopic>();
    Course course = new Course();
    private string WorksheetName = "";
    public string strSearch = "";
    public int intPageNumber = 1;
    public int _courseTopicId = 0;
    private int intPendingPageNumber = 1; //value typed in the input (prevent changing i (index number) of tests in list)
    public string strExcelFile = "";
    private int intExamId;
    public int i = 0;
    string _cmd = "";
    public bool _hasFetched = false;

    //LifeCycleEvents
    protected override async Task OnInitializedAsync ()
        {
        _hasFetched = false;
        appState.OnChange += TriggerRender;
        if (Convert.ToInt32(appState.UserLoginStatus) != 1)
            {
            Navman.NavigateTo("/Login");
            }
        lstCourseTopics = await feService.Read_CourseTopics(Convert.ToInt32(appState.CourseId));
        course.CourseId = Convert.ToInt32(appState.CourseId);
        switch (appState.Cmd)
            {
            case "ListCourseTests":
                    {
                    _courseTopicId = 0;
                    intPageNumber = 1;
                    await BtnReadTestsPaginated(1);
                    break;
                    }
            case "ListCourseTopicTests":
                    {
                    _courseTopicId = Convert.ToInt32(appState.CourseTopicId);
                    intPageNumber = 1;
                    await BtnReadTestsPaginated(1);
                    break;
                    }
            }
        lstExams.Clear();
        lstExams = await feService.Read_Exams(course.CourseId);
        intExamId = (Convert.ToInt32(appState.ExamId) > 0) ? Convert.ToInt32(appState.ExamId) : 0; //makes combo select the exam if any
        _hasFetched = true;
        }
    private void TriggerRender ()
        {
        InvokeAsync(StateHasChanged);
        }
    public void Dispose ()
        {
        appState.OnChange -= TriggerRender;
        }
    //SEARCH
    private async Task HandleKey_Searchbox (KeyboardEventArgs e)
        {
        if ((e.Key == "Enter") && (strSearch.Trim().Length >= 3))
            {
            appState.SetMessage("EnterKeyIsPressedForSearch");
            await BtnReadTestsBySearch();
            return;
            }
        if (e.Key == "Escape")
            {
            strSearch = "";
            await InvokeAsync(StateHasChanged);
            await txtSearch.FocusAsync();
            }
        }
    public async Task BtnReadTestsBySearch ()
        {
        intPendingPageNumber = 1;
        i = 0;
        int courseId = Convert.ToInt32(appState.CourseId);
        string courseName = appState.CourseName;
        lstCourseTests = await feService.Read_TestsBySearch(strSearch.Trim(), courseId, false);
        appState.SetMessage(""); //cancel flag: 'Enter is pressed for search'  (see: BtnCancel)
        PutTestsListIntoWorkingList();
        }
    //Autocomplete and Pagination
    private async Task<IEnumerable<int>> SearchCourseTopics (string value, CancellationToken ct)
        {
        // If nothing is typed, return all or a subset
        intPageNumber = 1;
        intPendingPageNumber = 1;
        if (string.IsNullOrEmpty(value))
            return lstCourseTopics.Select(x => x.CourseTopicId);
        // Filter the list
        return lstCourseTopics
            .Where(x => x.CourseTopicTitle.Contains(value, StringComparison.InvariantCultureIgnoreCase))
            .Select(x => x.CourseTopicId);
        }
    private string GetCourseTopicName (int id)
        {
        if (id == 0)
            return "";
        var courseTopic = lstCourseTopics.FirstOrDefault(a => a.CourseTopicId == id);
        return courseTopic != null ? $"{courseTopic.CourseTopicTitle}" : "";
        }
    private async Task ReadCourseTopicTests ()
        {
        intPendingPageNumber = 1;
        intPageNumber = 1;
        await BtnReadTestsPaginated(1);
        await Task.Delay(1);
        await refCourseTopics.FocusAsync();
        StateHasChanged();
        }
    public async Task BtnReadTestsPaginated (int newPage)
        {
        strSearch = "";
        intPageNumber = newPage;
        lstCourseTests.Clear();
        if (_courseTopicId == 0)
            {
            lstCourseTests = await feService.Read_TestsByCourseId(course.CourseId, intPageNumber, true);
            }
        else if (_courseTopicId >= 1)
            {
            lstCourseTests = await feService.Read_TestsByCourseTopicId(_courseTopicId, intPageNumber, true);
            }
        PutTestsListIntoWorkingList();
        }
    //btns
    public void BtnAddNewTest ()
        {
        appState.SetCmd("AddNewTest");
        Navman.NavigateTo("/T_CourseTest");
        }
    public void PutTestsListIntoWorkingList ()
        {
        lstxTests.Clear();
        foreach (Test tst in lstCourseTests)
            {
            lstxTests.Add(new StudentExamTest()
                {
                StudentExamId = tst.CourseId,
                TestId = tst.TestId,
                StudentExamTestKey = 0,
                StudentExamTestAns = 0,
                TestIndex = 0,
                TestTitle = tst.TestTitle,
                TestType = tst.TestType,
                CourseTopicId = tst.TopicId,
                CourseTopicTitle = "",
                TestTags = tst.TestTags,
                TestLevel = tst.TestLevel,
                TestOptions = tst.TestOptions
                }
            );
            }
        //find and set key
        foreach (StudentExamTest t in lstxTests)
            {
            foreach (TestOption opt in t.TestOptions)
                {
                if (opt.TestOptionTags >= 2)
                    {
                    t.StudentExamTestKey = opt.TestOptionId;
                    break;
                    }
                }
            }
        }
    public void BtnEditCourseTest (int testId)
        {
        appState.SetTestId(testId);
        appState.SetReturnPage("/T_CourseTests");
        Navman.NavigateTo("/T_CourseTest");
        }
    //selection
    public async Task BtnSelectAllTests ()
        {
        foreach (StudentExamTest test in lstxTests)
            {
            test.IsSelected = true;
            }
        StateHasChanged();
        }
    public async Task BtnInvertSelection ()
        {
        foreach (StudentExamTest test in lstxTests)
            {
            test.IsSelected = (test.IsSelected) ? false : true;
            }
        StateHasChanged();
        }
    //add to exam
    public async Task BtnAddSelectedTestsToAnExam ()
        {
        if (intExamId <= 0)
            {
            Snackbar.Add("select an exam", Severity.Info);
            //await JS.InvokeVoidAsync ("alert", "");
            }
        else
            {
            var selectedIds = lstxTests
                .Where(t => t.IsSelected)
                .Select(t => t.TestId)
                .ToList();
            int testCount = 0;
            foreach (int intTestId in selectedIds)
                {
                ExamTest examTest = new ExamTest() { ExamId = intExamId, TestId = intTestId };
                int result = await feService.Create_ExamTest(examTest);
                if (result > 0)
                    {
                    testCount++;
                    }
                }
            //appState.SetCmd ("coursetests");
            StateHasChanged();
            Snackbar.Add($"\n\n{testCount} tests added to the exam", Severity.Success); //{Severity.Warning .Error | .Info | .Success} --needs: @inject ISnackbar Snackbar
            //old code: await JS.InvokeVoidAsync ("alert", $"\n\n{testCount} Tests was added to the Exam Successfully")
            }
        }
    public async Task BtnEditExam ()
        {
        if (intExamId > 0)
            {
            Navman.NavigateTo($"/T_Exam/{intExamId}");
            }
        else
            {
            Snackbar.Add("select an exam", Severity.Info);
            //await JS.InvokeVoidAsync ("alert", "");
            }
        }
    //excel
    public void BtnImportFromExcelFile ()
        {
        appState.SetCmd("readexcelworksheets");
        }
    private async Task HandleFileSelected (InputFileChangeEventArgs e)
        {
        /*
        method 1: Save excel file to server folder
        mothod 2: Parse directly in memory
        method 3: EPPlus package (fast!)
        */
        try
