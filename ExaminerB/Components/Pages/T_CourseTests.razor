@page "/T_CourseTests"
@using ClosedXML.Excel
@using ExaminerB.Service
@using Microsoft.Extensions.Hosting
@using ClosedXML
@using Microsoft.VisualBasic
@inject FeService feService
@inject NavigationManager Navman
@inject AppState appState
@inject IJSRuntime JS
@implements IDisposable
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using OfficeOpenXml;

@if (!_hasFetched)
    {
    <_ScanSheets />
    }
else
    {
        <div style="text-align:center">
        <h3>@appState.CourseName</h3>
        <hr />
        </div>
        <EditForm Model="lstCourseTests" style="max-width:600px; margin: 0 auto;">
        @if (appState.Cmd == "readexcelworksheets")
            {
            <br />
                <MudContainer MaxWidth="MaxWidth.Small" Class="mt-2 px-0">
                    <MudCard Class="mx-0">
                        <MudCardContent Style="background-color:whitesmoke;">
                            <div>
                            <br />
                            <img src="/img/icoExcel1.png" width="28" style="margin-right:10px;" />
                            <InputFile OnChange="HandleFileSelected" title="Refer to Examiner guide for correct Excel format" />
                            </div>
                        <br /><br />
                        <hr />
                            <div style="text-align:center">
                            <MudIconButton Icon="@Icons.Material.Filled.HelpCenter" Color="Color.Tertiary" Size="Size.Large" OnClick="BtnHelpSignupNewTeacher" Title="how to import tests from excel" />
                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Primary" Size="Size.Large" OnClick="BtnCancel" Title="cancel" />
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudContainer>
            }
        else if (appState.Cmd == "importexcelworksheets")
            {
            <br />
                <MudContainer MaxWidth="MaxWidth.Small" Class="mt-2 px-0">
                    <MudCard Class="mx-0">
                        <MudCardContent Style="background-color:whitesmoke;">
                        <br />
                            <div class="d-flex">
                                <MudSelect T="string"
                                       @ref="refWorksheets"
                                       Label="Worksheet"
                                       Value="WorksheetName"
                                       ValueChanged="@((string worcksheetname) => OnWorksheetChanged(worcksheetname))"
                                       Class="w-auto"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Style="font-size:small;">
                                @foreach (string ws in lstWorksheets)
                                    {
                                    <MudSelectItem Value="@ws">@ws</MudSelectItem>
                                    }
                                </MudSelect>
                                <button class="btn btn-link" Title="import from excel" @onclick="() => ReadExcelAsync()">
                                <img src="/img/icoGo1.png" width="36" />
                                </button>
                            </div>
                        <br /><br />
                        <hr />
                            <div style="text-align:center">
                                <button class="btn btn-link" style="margin-right:20px;" @onclick="BtnCancel">
                                <img src="/img/icoCancel.png" width="24" />
                                </button>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudContainer>
            }
        else
            {
                <button class="btn btn-link" @onclick="BtnBack">
                <img src="/img/icoBack3.png" width="40" title="back" />
                </button>
                <button class="btn btn-link" @onclick="BtnImportFromExcelFile">
                <img src="/img/icoExcel1.png" width="28" title="import tests from excel" />
                </button>
                <button class="btn btn-link" @onclick="() => BtnAddNewTest()">
                <img src="/img/icoAdd0.png" width="24" title="add a new test" />
                </button>
            <hr style="border-color:red" />
            <h3>@course.CourseName</h3>
            @* SEARCH *@
                <div class="d-flex gap-2 mb-3 pt-1 pb-1" tabindex="0 ">
                <MudTextField @ref="txtSearch"
                              @bind-Value="strSearch"
                              OnKeyDown="HandleKey_Searchbox"
                              Label="Search"
                              Variant="Variant.Text"
                              Margin="Margin.Dense"
                              Immediate="true"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              OnAdornmentClick="BtnReadTestsBySearch"
                              Style="font-family:tahoma"
                              Class="my-textfield" />
                </div>
                <div class="d-flex gap-4 mb-3 align-items-center align-content-center" tabindex="1">
                @* Autocomplete *@
                    <MudAutocomplete T="int"
                                 @ref="refCourseTopics"
                                 @bind-Value="_courseTopicId"
                                 Label="Topic"
                                 SearchFunc="@SearchCourseTopics"
                                 ToStringFunc="GetCourseTopicName"
                                 Variant="Variant.Text"
                                 Margin="Margin.Dense"
                                 Adornment="Adornment.End"
                                 AdornmentIcon="@Icons.Material.Filled.List"
                                 OnAdornmentClick="ReadCourseTopicTests"
                                 style="font-family:tahoma;text-align:right;font-size:small;color:royalblue;">
                        <ItemTemplate Context="courseTopicId">
                            <span style="font-family:tahoma; font-size:small; text-align:right; display:block;">
                            @GetCourseTopicName(courseTopicId)
                            </span>
                        </ItemTemplate>
                    </MudAutocomplete>
                    <div class="d-flex align-items-center align-content-center" tabindex="1">
                    @* Paginate *@
                    <MudNumericField T="int"
                                     @ref="refPageNumber"
                                     @bind-Value="intPendingPageNumber"
                                     Label="Page"
                                     Variant="Variant.Text"
                                     Margin="Margin.Dense" Autocomplete="off"
                                     Adornment="Adornment.End"
                                     AdornmentIcon="@Icons.Material.Filled.List"
                                     OnAdornmentClick="async ()=> await BtnReadTestsPaginated(intPendingPageNumber)"
                                     Class="my-textfield"
                                     style="padding-left:10px;padding-right:20px;max-width:180px; "
                                     Min="1" />
                    </div>
                </div>

            @* List of tests *@
            <hr style="color:red;margin-top:40px;" />
                <div class="d-flex gap-4 justify-content-center" style="margin-top:15px">
                <MudIconButton Icon="@Icons.Material.Filled.DoneAll" Color="Color.Primary" Size="Size.Medium" OnClick="BtnSelectAllTests" Title="Select All" />
                <MudIconButton Icon="@Icons.Material.Filled.Rule" Color="Color.Primary" Size="Size.Medium" OnClick="BtnInvertSelection" Title="Invert Selection" />
                </div>
            i = (intPageNumber - 1) * 20; //important: see pageSize in BackendService
            @foreach (var tst in lstxTests)
                {
                int localId = tst.TestId;
                    <MudContainer Class="mt-2 px-0">
                        <MudCard Class="mx-0">
                            <MudCardContent Style="background-color:whitesmoke;">
                                @{
                                string testRtlStatus = ((tst.TestTags & 1) == 1) ? "direction:rtl;text-align:right;" : "";
                                string optRtlStatus = ((tst.TestTags & 2) == 2) ? "direction:rtl;text-align:right;" : "";
                                i++;
                                }
                            <div style="font-weight:bold; @testRtlStatus">@i - @tst.TestTitle</div>
                                <div style="@testRtlStatus display:flex; align-items:center; gap:2px;">
                                <input class="form-check-input" style="margin-left:5px;margin-right:5px;" type="checkbox" @bind="tst.IsSelected" />
                                    <button class="btn btn-link" style="@testRtlStatus" @onclick="() => BtnEditCourseTest(tst.TestId)">
                                    <img src="/img/icoEditPen.png" title="Eedit test" alt="Edit" width="18px" />
                                    </button>
                                </div>
                            @* Show-TestOptions *@
                            @foreach (var opt in tst.TestOptions)
                                {
                                if ((opt.TestOptionId == tst.StudentExamTestKey) & (opt.TestOptionId != tst.StudentExamTestAns))
                                    {
                                    <div style="color:blue; @optRtlStatus"> - @opt.TestOptionTitle</div>
                                    }
                                else if ((opt.TestOptionId != tst.StudentExamTestKey) & (opt.TestOptionId != tst.StudentExamTestAns))
                                    {
                                    <div style="color:black; @optRtlStatus"> - @opt.TestOptionTitle</div>
                                    }
                                }
                            </MudCardContent>
                        </MudCard>
                    </MudContainer>
                }
                <div id="loadingOverlay" class="d-none">
                    <div class="position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 z-3 d-flex justify-content-center align-items-center">
                        <div class="text-center bg-white p-4 rounded shadow">
                        <div class="spinner-border text-primary mb-3" role="status"></div>
                        <p class="mb-0 fw-semibold">Please wait, processing...</p>
                        </div>
                    </div>
                </div>
            <hr style="color:red" />
                <MudContainer MaxWidth="MaxWidth.Small" Class="mt-2 px-0">
                    <MudCard Class="mx-0">
                        <MudCardContent Style="background-color:whitesmoke;">
                        <div style="font-weight:bold;color:royalblue;padding-bottom:5px;">Add selected tests to:</div>
                            <div class="d-flex mb-3 align-content-center align-items-center justify-content-center" ">
                                <MudSelect T="int"
                                       Label="Exam"
                                       @bind-Value="intExamId"
                                       Class="w-auto my-select"
                                       Variant="Variant.Text"
                                       Margin="Margin.Dense"
                                       Adornment="Adornment.End"
                                       AdornmentIcon="@Icons.Material.Filled.Add"
                                       OnAdornmentClick="BtnAddSelectedTestsToAnExam"
                                       Style="color:royalblue;width:140px;font-size:small;padding-top:10px;">
                                <MudSelectItem Value="0">Select an Exam...</MudSelectItem>
                                @foreach (Exam exam in lstExams)
                                    {
                                    <MudSelectItem Value="@exam.ExamId">@exam.ExamTitle</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                            <div class="d-flex m-4 gap-1 align-items-center align-content-center justify-content-center" style="text-align: center;">
                                <button class="btn btn-link pulse-hover" type="submit" @onclick="BtnEditExam">
                                <img src="/img/icoFolderE.png" width="26" title="show exam page" />
                                </button>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudContainer>
                <div style="max-width:500px; margin: 0 auto; text-align:center;">
                <br />
                    <button class="btn btn-link" @onclick="BtnBack">
                    <img src="/img/icoBack3.png" width="40" />
                    </button>
                </div>
            }
        </EditForm>
    }
@if (_cmd == "guide")
    {
    <hr />
    <_GuideImportTests />
    <br />
        <div class="d-flex justify-content-center">
            <MudButton Variant="Variant.Filled"
                   EndIcon="@Icons.Material.Filled.CheckCircle"
                   Size="Size.Small"
                   OnClick="@(() => BtnCancelGuide())"
                   Style="color:dimgray;">
            ok, got it
            </MudButton>
        </div>
    }

