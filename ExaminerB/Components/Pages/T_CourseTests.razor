            }
        */
        }
    private async Task OnWorksheetChanged (string newValue)
        {
        WorksheetName = newValue;
        await Task.Delay(1);
        await refWorksheets.FocusAsync();
        StateHasChanged();
        }
    private async Task ReadExcelAsync ()
        {
        if (WorksheetName == "")
            {
            Snackbar.Add("select a worksheet", Severity.Warning);
            return;
            }
        else
            {
            _hasFetched = false;
            var message = new MarkupString($"<hr>CONFIRM: <br><br>Tests in the <span style='color:indianred'>Selected</span><span style='color:royalblue'> Excel Worksheet</span> will be imported <br><br><span style='font-weight:bold'>Duplicate tests</span><br>are imported without warning! <span style='color:indianred'><br><br>Continue .... </span>?<br><br><div style='text-align:center'><img src='/img/icoExcel1.png' width='70'/></div><br><hr>");
            bool? confirmResult = await DialogService.ShowMessageBox(title: "Confirm", markupMessage: message, yesText: "Yes", cancelText: "No");
            if (confirmResult == true)
                {
                _hasFetched = false;
                stream.Position = 0;
                try
                    {
                    List<CourseTopic> lstCourseTopics = await feService.Read_CourseTopics(course.CourseId);
                    using var wb = new XLWorkbook(stream);
                    var worksheet = wb.Worksheet($"{WorksheetName}");
                    //ExcelColumns: 1:Topic 2:Question 3:nOpts 4-8:Opts 9:Ans 10:ForceLast 11:TestRtl 12:OptRtl 13:Level
                    foreach (var row in worksheet.RowsUsed().Skip(1)) //skip header
                        {
                        Test test = new Test();
                        test.CourseId = course.CourseId;
                        test.TopicId = 0;
                        test.TestTitle = row.Cell(2).GetString();
                        test.TestType = row.Cell(3).GetValue<int>();
                        test.TestType = (test.TestType == 1) ? 0 : test.TestType;
                        test.TestType = (test.TestType > 5) ? 5 : test.TestType;
                        test.TestLevel = row.Cell(13).GetValue<int>();
                        test.TestTags = 0;
                        if (row.Cell(11).GetString().ToLower() == "r")
                            test.TestTags += 1;
                        if (row.Cell(12).GetString().ToLower() == "r")
                            test.TestTags += 2;
                        test.TestOptions = new List<TestOption>();
                        //Topic handling
                        string crsTestTopic = row.Cell(1).GetString().Trim();
                        crsTestTopic = crsTestTopic.Length > 30 ? crsTestTopic [..30] : crsTestTopic;
                        var existingTopic = lstCourseTopics.FirstOrDefault(t => string.Equals(t.CourseTopicTitle, crsTestTopic, StringComparison.OrdinalIgnoreCase));
                        if (existingTopic != null)
                            {
                            test.TopicId = existingTopic.CourseTopicId;
                            }
                        else
                            {
                            CourseTopic newCourseTopic = new CourseTopic { CourseId = course.CourseId, CourseTopicTitle = crsTestTopic };
                            test.TopicId = await feService.Create_CourseTopic(newCourseTopic);
                            newCourseTopic.CourseTopicId = test.TopicId;
                            lstCourseTopics.Add(newCourseTopic);
                            }
                        //Options
                        for (int col = 4; col < test.TestType + 4; col++)
                            {
                            var strOpt = row.Cell(col).GetString();
                            test.TestOptions.Add(new TestOption { TestOptionTitle = strOpt, TestId = 1 }); //initialize TestId here and set the value when test is saved to DB
                            }
                        //Answer
                        int answ = row.Cell(9).GetValue<int>();
                        if (answ > 0 && answ <= test.TestOptions?.Count)
                            {
                            test.TestOptions [answ - 1].TestOptionTags = 2; //2:IsAns
                            }
                        //ForceLast
                        int forceLast = row.Cell(10).GetValue<int>();
                        if (forceLast > 0 && forceLast <= test.TestOptions?.Count)
                            {
                            test.TestOptions [forceLast - 1].TestOptionTags += 1; //1:ForceLast
                            }
                        //Create New Test+Options
                        test.TestId = await feService.Create_Test(test);
                        }
                    }
                catch (Exception ex)
                    {
                    Console.WriteLine($"Error in [ImportExcel]: {ex}");
                    }
                lstWorksheets.Clear();
                lstCourseTests.Clear();
                lstCourseTests = await feService.Read_TestsByCourseId(Convert.ToInt32(appState.CourseId), intPageNumber, false);
                lstCourseTopics = await feService.Read_CourseTopics (Convert.ToInt32 (appState.CourseId));
                Snackbar.Add("data imported", Severity.Success);
                _hasFetched = true;
                appState.SetCmd("");
                }
            }
        }
